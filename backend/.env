# SpeechCoach Backend Environment Variables
# No API keys needed — Ollama runs locally!

# Ollama model to use for speech analysis feedback
# Available on your system: llama3.2, qwen2.5-coder:14b
OLLAMA_MODEL=gemma4:31b-cloud

# Ollama server address (default is localhost)
OLLAMA_HOST=http://localhost:11434
